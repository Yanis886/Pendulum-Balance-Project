const int stepPin = 6; 
const int dirPin = 5; 

//8833 maybe 
//1600 ticks per rev

// Tuning parameters
const int pulseWidth = 500;       // Microseconds the pulse stays HIGH/LOW
const unsigned long pauseTime = 1000; // Time to wait between steps (in milliseconds)

long totalTicks = 0;             // Step counter

void setup() {
  pinMode(stepPin, OUTPUT);
  pinMode(dirPin, OUTPUT);
  digitalWrite(dirPin, HIGH);    // Set initial direction
  
  Serial.begin(9600);            // Initialize serial communication
  Serial.println("Motor starting...");
}

void loop() {
  if (totalTicks<8800){
  // 1. Move exactly one step
  digitalWrite(stepPin, HIGH);
  delayMicroseconds(pulseWidth); 
  digitalWrite(stepPin, LOW);
  delayMicroseconds(pulseWidth); 
  
  // 2. Increment and print the total steps
  totalTicks++;
  Serial.print("Total ticks: ");
  Serial.println(totalTicks);
  
  // 3. Pause so you can observe the physical movement
  
  } 
}
